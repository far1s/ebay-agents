{
  "version": 2,
  "builds": [
    {
      "src": "dashboard/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": [
          "tools/**",
          "agents/**",
          "crew/**",
          "api/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/api/ping", "dest": "api/ping.py" },
    { "src": "/api/(.*)", "dest": "api/main.py" },
    { "src": "/_next/(.*)", "dest": "/dashboard/_next/$1" },
    { "src": "/favicon.ico", "dest": "/dashboard/favicon.ico" },
    { "src": "^/(agents|listings|logs|settings)(/?.*)", "dest": "/dashboard/$1$2" },
    { "src": "^/$", "dest": "/dashboard" }
  ],
  "crons": [
    {
      "path": "/api/schedule/run",
      "schedule": "0 9 * * *"
    }
  ]
}
