# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── eBay Developer ─────────────────────────────────────────────────────────────
# Get keys at: https://developer.ebay.com/my/keys
EBAY_APP_ID=YourApp-YourApp-SBX-xxxxxxxx-xxxxxxxx
EBAY_CERT_ID=SBX-xxxxxxxxxxxxxxxx-xxxxxxxx-xxxx-xxxx
EBAY_DEV_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Generate user token via eBay OAuth flow (see README)
EBAY_USER_TOKEN=v^1.1#i^1#r^0#...
EBAY_SANDBOX_MODE=true

# ── Telegram ───────────────────────────────────────────────────────────────────
# Create bot via @BotFather on Telegram (see README)
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff-1234567890
# Get your chat ID by messaging @userinfobot
TELEGRAM_CHAT_ID=123456789

# ── Supabase ───────────────────────────────────────────────────────────────────
# Create project at: https://supabase.com
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Dashboard ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── App Settings ───────────────────────────────────────────────────────────────
# Folder where generated PDFs are stored
PDF_OUTPUT_DIR=./generated_pdfs
# Maximum days to keep generated PDFs before cleanup
PDF_RETENTION_DAYS=30
