# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Etsy Developer ─────────────────────────────────────────────────────────────
# 1. Create an app at: https://www.etsy.com/developers/register
# 2. Copy the API key (Keystring) here
ETSY_API_KEY=your_etsy_api_key_here
# 3. Find your shop ID: https://www.etsy.com/your/shops/me/tools/listings
#    or via API: GET /application/users/me → primary_email → shop_id
ETSY_SHOP_ID=12345678
# 4. Complete the OAuth 2.0 flow to get an access token (see README for steps)
ETSY_ACCESS_TOKEN=your_oauth_access_token_here

# ── Telegram ───────────────────────────────────────────────────────────────────
# Create bot via @BotFather on Telegram (see README)
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff-1234567890
# Get your chat ID by messaging @userinfobot
TELEGRAM_CHAT_ID=123456789

# ── Supabase ───────────────────────────────────────────────────────────────────
# Create project at: https://supabase.com
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Dashboard ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── App Settings ───────────────────────────────────────────────────────────────
# Folder where generated PDFs are stored
PDF_OUTPUT_DIR=./generated_pdfs
# Maximum days to keep generated PDFs before cleanup
PDF_RETENTION_DAYS=30
